<Page x:Class="DigitalTwin.Views.RulesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Rules &amp; Tags"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">
            
            <!-- Header Section -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Kurallar ve Etiketler" 
                          FontSize="32" 
                          FontWeight="Bold" 
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Margin="0,0,0,8"/>
                <TextBlock Text="Uygulamalarınızı kategorize edin ve üretkenlik kuralları belirleyin" 
                          FontSize="14" 
                          Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <!-- Add New Tag -->
            <Border Background="{StaticResource SecondaryBrush}" 
                   Opacity="0.1"
                   CornerRadius="20" 
                   Padding="32" 
                   Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="➕ Yeni Etiket Ekle" 
                              FontSize="20" 
                              FontWeight="Bold" 
                              Foreground="{StaticResource SecondaryBrush}"
                              Margin="0,0,0,20"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0"
                                Text="Etiket adını girin..."
                                Padding="16,12"
                                FontSize="14"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                VerticalAlignment="Center"/>
                        
                        <Button Grid.Column="2"
                               Content="Etiket Ekle"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Padding="24,12"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Tag Categories -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Productive Tag -->
                <Border Grid.Column="0"
                       Background="{StaticResource SurfaceBrush}"
                       CornerRadius="16"
                       Padding="24"
                       Effect="{StaticResource ShadowMD}">
                    <StackPanel>
                        <Border Width="48" Height="48"
                               Background="{StaticResource SuccessBrush}"
                               Opacity="0.15"
                               CornerRadius="12"
                               Margin="0,0,0,16">
                            <TextBlock Text="✅" 
                                      FontSize="24" 
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Üretken" 
                                  FontSize="16" 
                                  FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="0 uygulama" 
                                  FontSize="14" 
                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Neutral Tag -->
                <Border Grid.Column="2"
                       Background="{StaticResource SurfaceBrush}"
                       CornerRadius="16"
                       Padding="24"
                       Effect="{StaticResource ShadowMD}">
                    <StackPanel>
                        <Border Width="48" Height="48"
                               Background="{StaticResource InfoBrush}"
                               Opacity="0.15"
                               CornerRadius="12"
                               Margin="0,0,0,16">
                            <TextBlock Text="➖" 
                                      FontSize="24" 
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Nötr" 
                                  FontSize="16" 
                                  FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="0 uygulama" 
                                  FontSize="14" 
                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Distracting Tag -->
                <Border Grid.Column="4"
                       Background="{StaticResource SurfaceBrush}"
                       CornerRadius="16"
                       Padding="24"
                       Effect="{StaticResource ShadowMD}">
                    <StackPanel>
                        <Border Width="48" Height="48"
                               Background="{StaticResource ErrorBrush}"
                               Opacity="0.15"
                               CornerRadius="12"
                               Margin="0,0,0,16">
                            <TextBlock Text="⚠️" 
                                      FontSize="24" 
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Dikkat Dağıtıcı" 
                                  FontSize="16" 
                                  FontWeight="SemiBold"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="0 uygulama" 
                                  FontSize="14" 
                                  Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Application List -->
            <Border Background="{StaticResource SurfaceBrush}" 
                   CornerRadius="16" 
                   Padding="24"
                   Effect="{StaticResource ShadowMD}">
                <StackPanel>
                    <TextBlock Text="📱 Uygulama Etiketleri" 
                              FontSize="18" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,0,0,16"/>
                    
                    <Border Background="{StaticResource BackgroundSecondaryBrush}"
                           CornerRadius="12"
                           Padding="32"
                           MinHeight="200">
                        <TextBlock Text="Henüz etiketlenmiş uygulama yok.&#x0a;Daha iyi içgörüler elde etmek için uygulamalarınızı kategorize etmeye başlayın!" 
                                  VerticalAlignment="Center" 
                                  HorizontalAlignment="Center"
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  FontSize="14"
                                  TextWrapping="Wrap"
                                  TextAlignment="Center"
                                  LineHeight="24"/>
                    </Border>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Page>
