<Page x:Class="DigitalTwin.Views.AboutView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="About"
      Background="Transparent">

    <Page.Resources>
        <!-- Link Button Style -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                               Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource PrimaryHoverBrush}"/>
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Center">
        <Border MaxWidth="600" Margin="40">
            <StackPanel>
                
                <!-- Main Card Container -->
                <Border Background="{StaticResource SurfaceBrush}" 
                       CornerRadius="24" 
                       Padding="48"
                       Effect="{StaticResource ShadowLG}">
                    <StackPanel HorizontalAlignment="Center">
                        
                        <!-- Logo - Perfect Circle with Shadow -->
                        <Border Width="160" 
                               Height="160" 
                               CornerRadius="80"
                               Margin="0,0,0,32"
                               Effect="{StaticResource ShadowMD}">
                            <Border.Background>
                                <ImageBrush ImageSource="/logo.jpg" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Border.Clip>
                                <EllipseGeometry Center="80,80" RadiusX="80" RadiusY="80"/>
                            </Border.Clip>
                        </Border>

                        <!-- App Title -->
                        <TextBlock Text="Digital Twin" 
                                  FontSize="36" 
                                  FontWeight="Bold" 
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,12"/>

                        <!-- Version -->
                        <TextBlock Text="Version 1.0.0" 
                                  FontSize="16" 
                                  FontWeight="Medium"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,16"/>

                        <!-- Subtitle -->
                        <TextBlock Text="Modern WPF tabanlı dijital ikiz uygulaması" 
                                  FontSize="14" 
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  HorizontalAlignment="Center"
                                  TextAlignment="Center"
                                  Margin="0,0,0,32"/>

                        <!-- Divider -->
                        <Border Height="1" 
                               Background="{StaticResource BorderLightBrush}"
                               Margin="0,0,0,32"/>

                        <!-- Description -->
                        <TextBlock TextWrapping="Wrap"
                                  FontSize="14"
                                  LineHeight="24"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  TextAlignment="Center"
                                  Margin="0,0,0,32">
                            <Run Text="Eğer uygulama hakkında daha fazla bilgi almak veya son güncellemeleri takip etmek isterseniz GitHub profilimizi veya resmi web sitemizi ziyaret edebilirsiniz."/>
                        </TextBlock>

                        <!-- Links Section -->
                        <Border Background="{StaticResource BackgroundSecondaryBrush}"
                               CornerRadius="16"
                               Padding="24">
                            <StackPanel>
                                
                                <!-- GitHub Link -->
                                <StackPanel Orientation="Horizontal" 
                                           Margin="0,0,0,20">
                                    <Border Width="40" 
                                           Height="40"
                                           Background="{StaticResource PrimarySubtleBrush}"
                                           CornerRadius="10"
                                           Margin="0,0,16,0">
                                        <TextBlock Text="🔗" 
                                                  FontSize="20"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="GitHub" 
                                                  FontSize="14" 
                                                  FontWeight="SemiBold"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Margin="0,0,0,4"/>
                                        <Button Content="https://github.com/Bedirxan36"
                                               Style="{StaticResource LinkButtonStyle}"
                                               Click="OpenGitHub"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Website Link -->
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="40" 
                                           Height="40"
                                           Background="{StaticResource AccentBrush}"
                                           Opacity="0.15"
                                           CornerRadius="10"
                                           Margin="0,0,16,0">
                                        <TextBlock Text="🌐" 
                                                  FontSize="20"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Web Sitesi" 
                                                  FontSize="14" 
                                                  FontWeight="SemiBold"
                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                  Margin="0,0,0,4"/>
                                        <Button Content="https://dogantechh.web.app/"
                                               Style="{StaticResource LinkButtonStyle}"
                                               Click="OpenWebsite"/>
                                    </StackPanel>
                                </StackPanel>
                                
                            </StackPanel>
                        </Border>

                        <!-- Footer -->
                        <TextBlock Text="© 2026 Digital Twin. Tüm hakları saklıdır." 
                                  FontSize="12" 
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  HorizontalAlignment="Center"
                                  Margin="0,32,0,0"/>
                        
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </Border>
    </ScrollViewer>
</Page>
