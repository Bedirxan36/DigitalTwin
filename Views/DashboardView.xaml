<Page x:Class="DigitalTwin.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Dashboard"
      Background="Transparent">

    <Page.Resources>
        <!-- Card Hover Animation -->
        <Style x:Key="AnimatedCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect" Value="{StaticResource ShadowMD}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.02" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.02" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">
            
            <!-- Header Section -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Kontrol Paneli" 
                          FontSize="32" 
                          FontWeight="Bold" 
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Margin="0,0,0,8"/>
                <TextBlock Text="Üretkenlik bilgilerinize bir bakışta ulaşın" 
                          FontSize="14" 
                          Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <!-- Tracking Control -->
            <Border Background="{StaticResource PrimaryGradientBrush}" 
                   CornerRadius="20" 
                   Padding="32" 
                   Margin="0,0,0,24"
                   Effect="{StaticResource ShadowLG}"
                   RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <StackPanel>
                    <TextBlock Text="⚡ Aktivite Takibi" 
                              FontSize="20" 
                              FontWeight="Bold" 
                              Foreground="White"
                              Margin="0,0,0,20"/>
                    
                    <StackPanel Orientation="Horizontal">
                        <Button Content="▶️ Takibi Başlat" 
                               Command="{Binding StartTrackingCommand}"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Background="White"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,12,0"/>
                        
                        <Button Content="⏸️ Takibi Durdur" 
                               Command="{Binding StopTrackingCommand}"
                               Style="{StaticResource SecondaryButtonStyle}"
                               BorderBrush="White"
                               Foreground="White"/>
                    </StackPanel>
                    
                    <TextBlock Text="{Binding TrackingStatus}" 
                              FontSize="14"
                              Foreground="White"
                              FontWeight="Medium"
                              Opacity="0.9"
                              Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <!-- Stats Grid -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Time Card -->
                <Border Grid.Column="0"
                       Style="{StaticResource AnimatedCardStyle}"
                       Padding="24"
                       RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <Border Width="56" Height="56"
                               Background="{StaticResource PrimarySubtleBrush}"
                               CornerRadius="14"
                               Margin="0,0,0,16">
                            <TextBlock Text="⏱️" 
                                      FontSize="28" 
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Bugünkü Toplam Süre" 
                                  FontSize="13" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalTimeToday}" 
                                  FontSize="32" 
                                  FontWeight="Bold" 
                                  Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Focus Sessions Card -->
                <Border Grid.Column="2"
                       Style="{StaticResource AnimatedCardStyle}"
                       Padding="24"
                       RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <Border Width="56" Height="56"
                               Background="{StaticResource AccentBrush}"
                               Opacity="0.15"
                               CornerRadius="14"
                               Margin="0,0,0,16">
                            <TextBlock Text="🎯" 
                                      FontSize="28" 
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Odak Oturumları" 
                                  FontSize="13" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding FocusSessionCount}" 
                                  FontSize="32" 
                                  FontWeight="Bold" 
                                  Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Productivity Score Card -->
                <Border Grid.Column="4"
                       Style="{StaticResource AnimatedCardStyle}"
                       Padding="24"
                       RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <StackPanel>
                        <Border Width="56" Height="56"
                               Background="{StaticResource SuccessBrush}"
                               Opacity="0.15"
                               CornerRadius="14"
                               Margin="0,0,0,16">
                            <TextBlock Text="📈" 
                                      FontSize="28" 
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Üretkenlik Skoru" 
                                  FontSize="13" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding ProductivityScore}" 
                                  FontSize="32" 
                                  FontWeight="Bold" 
                                  Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Activity -->
            <Border Background="{StaticResource SurfaceBrush}" 
                   CornerRadius="16" 
                   Padding="24" 
                   Margin="0,0,0,24"
                   Effect="{StaticResource ShadowMD}">
                <StackPanel>
                    <TextBlock Text="Son Aktiviteler" 
                              FontSize="18" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,0,0,16"/>
                    
                    <ItemsControl ItemsSource="{Binding RecentActivities}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BackgroundSecondaryBrush}" 
                                       CornerRadius="12" 
                                       Padding="16" 
                                       Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Grid.Column="0"
                                                  Text="📱" 
                                                  FontSize="20"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,16,0"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ApplicationName}" 
                                                      FontWeight="SemiBold" 
                                                      FontSize="14"
                                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding WindowTitle}" 
                                                      FontSize="12"
                                                      Foreground="{StaticResource TextSecondaryBrush}"
                                                      TextTrimming="CharacterEllipsis"
                                                      Margin="0,4,0,0"/>
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2"
                                                  Text="{Binding Duration}" 
                                                  FontSize="14"
                                                  FontWeight="Medium"
                                                  Foreground="{StaticResource PrimaryBrush}"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Recommendations -->
            <Border Background="{StaticResource SurfaceBrush}" 
                   CornerRadius="16" 
                   Padding="24"
                   Effect="{StaticResource ShadowMD}">
                <StackPanel>
                    <TextBlock Text="💡 Akıllı Öneriler" 
                              FontSize="18" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,0,0,16"/>
                    
                    <ItemsControl ItemsSource="{Binding RecentRecommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource PrimarySubtleBrush}" 
                                       BorderBrush="{StaticResource PrimaryLightBrush}"
                                       BorderThickness="1"
                                       CornerRadius="12" 
                                       Padding="20" 
                                       Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" 
                                                  FontWeight="SemiBold" 
                                                  FontSize="15"
                                                  Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Message}" 
                                                  TextWrapping="Wrap" 
                                                  FontSize="14"
                                                  Foreground="{StaticResource TextSecondaryBrush}"
                                                  Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding Reasoning}" 
                                                  FontSize="12" 
                                                  Foreground="{StaticResource TextTertiaryBrush}" 
                                                  FontStyle="Italic"
                                                  TextWrapping="Wrap"
                                                  Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Page>
