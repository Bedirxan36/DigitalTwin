<Page x:Class="DigitalTwin.Views.FocusSessionView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Focus Session"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">
            
            <!-- Header Section -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Odak Oturumu" 
                          FontSize="32" 
                          FontWeight="Bold" 
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Margin="0,0,0,8"/>
                <TextBlock Text="Odaklanmış bir çalışma oturumu başlatın ve üretkenliğinizi takip edin" 
                          FontSize="14" 
                          Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <!-- Focus Timer Card -->
            <Border Background="{StaticResource SuccessGradientBrush}" 
                   CornerRadius="24" 
                   Padding="48" 
                   Margin="0,0,0,24"
                   Effect="{StaticResource ShadowXL}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🎯" 
                              FontSize="64" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,24"/>
                    
                    <TextBlock Text="00:00:00" 
                              FontSize="56" 
                              FontWeight="Bold" 
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,32"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="▶️ Oturumu Başlat" 
                               Style="{StaticResource PrimaryButtonStyle}"
                               Background="White"
                               Foreground="{StaticResource SuccessBrush}"
                               Padding="32,16"
                               FontSize="16"
                               Margin="0,0,12,0"/>
                        
                        <Button Content="⏸️ Duraklat" 
                               Style="{StaticResource SecondaryButtonStyle}"
                               BorderBrush="White"
                               Foreground="White"
                               Padding="32,16"
                               FontSize="16"
                               Margin="0,0,12,0"/>
                        
                        <Button Content="⏹️ Durdur" 
                               Style="{StaticResource SecondaryButtonStyle}"
                               BorderBrush="White"
                               Foreground="White"
                               Padding="32,16"
                               FontSize="16"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Session Stats -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                       Background="{StaticResource SurfaceBrush}"
                       CornerRadius="16"
                       Padding="24"
                       Effect="{StaticResource ShadowMD}">
                    <StackPanel>
                        <TextBlock Text="📊 Bugünkü Oturumlar" 
                                  FontSize="16" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  Margin="0,0,0,12"/>
                        <TextBlock Text="0" 
                                  FontSize="36" 
                                  FontWeight="Bold" 
                                  Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                       Background="{StaticResource SurfaceBrush}"
                       CornerRadius="16"
                       Padding="24"
                       Effect="{StaticResource ShadowMD}">
                    <StackPanel>
                        <TextBlock Text="⏱️ Toplam Odak Süresi" 
                                  FontSize="16" 
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  Margin="0,0,0,12"/>
                        <TextBlock Text="0h 0m" 
                                  FontSize="36" 
                                  FontWeight="Bold" 
                                  Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Sessions -->
            <Border Background="{StaticResource SurfaceBrush}" 
                   CornerRadius="16" 
                   Padding="24"
                   Effect="{StaticResource ShadowMD}">
                <StackPanel>
                    <TextBlock Text="📝 Son Oturumlar" 
                              FontSize="18" 
                              FontWeight="SemiBold" 
                              Foreground="{StaticResource TextPrimaryBrush}"
                              Margin="0,0,0,16"/>
                    
                    <Border Background="{StaticResource BackgroundSecondaryBrush}"
                           CornerRadius="12"
                           Padding="32"
                           MinHeight="200">
                        <TextBlock Text="Henüz odak oturumu yok.&#x0a;Üretkenliğinizi takip etmek için ilk oturumunuzu başlatın!" 
                                  VerticalAlignment="Center" 
                                  HorizontalAlignment="Center"
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  FontSize="14"
                                  TextWrapping="Wrap"
                                  TextAlignment="Center"
                                  LineHeight="24"/>
                    </Border>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Page>
