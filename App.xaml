<Application x:Class="DigitalTwin.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:DigitalTwin.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Shadows.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Global Converters -->
            <conv:LocalizationConverter x:Key="LocalizationConverter"/>
            <conv:TrackingButtonConverter x:Key="TrackingButtonConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
