<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
    ═══════════════════════════════════════════════════════════════
    SHADOW SYSTEM - Soft & Layered Elevation
    ═══════════════════════════════════════════════════════════════
    -->

    <!-- Shadow Levels -->
    
    <!-- XS - Subtle hover effect -->
    <DropShadowEffect x:Key="ShadowXS" 
                     Color="#000000" 
                     Opacity="0.05" 
                     BlurRadius="4" 
                     ShadowDepth="1" 
                     Direction="270"/>
    
    <!-- SM - Small cards, buttons -->
    <DropShadowEffect x:Key="ShadowSM" 
                     Color="#000000" 
                     Opacity="0.08" 
                     BlurRadius="8" 
                     ShadowDepth="2" 
                     Direction="270"/>
    
    <!-- MD - Cards, panels -->
    <DropShadowEffect x:Key="ShadowMD" 
                     Color="#000000" 
                     Opacity="0.10" 
                     BlurRadius="16" 
                     ShadowDepth="4" 
                     Direction="270"/>
    
    <!-- LG - Elevated panels, modals -->
    <DropShadowEffect x:Key="ShadowLG" 
                     Color="#000000" 
                     Opacity="0.12" 
                     BlurRadius="24" 
                     ShadowDepth="8" 
                     Direction="270"/>
    
    <!-- XL - Floating elements, tooltips -->
    <DropShadowEffect x:Key="ShadowXL" 
                     Color="#000000" 
                     Opacity="0.15" 
                     BlurRadius="32" 
                     ShadowDepth="12" 
                     Direction="270"/>
    
    <!-- 2XL - Dialogs, overlays -->
    <DropShadowEffect x:Key="Shadow2XL" 
                     Color="#000000" 
                     Opacity="0.18" 
                     BlurRadius="48" 
                     ShadowDepth="16" 
                     Direction="270"/>
    
    <!-- Colored Shadows -->
    
    <!-- Primary Shadow -->
    <DropShadowEffect x:Key="ShadowPrimary" 
                     Color="#6366F1" 
                     Opacity="0.25" 
                     BlurRadius="20" 
                     ShadowDepth="4" 
                     Direction="270"/>
    
    <!-- Success Shadow -->
    <DropShadowEffect x:Key="ShadowSuccess" 
                     Color="#22C55E" 
                     Opacity="0.25" 
                     BlurRadius="20" 
                     ShadowDepth="4" 
                     Direction="270"/>
    
    <!-- Inner Shadow Effect (for pressed states) -->
    <DropShadowEffect x:Key="ShadowInner" 
                     Color="#000000" 
                     Opacity="0.15" 
                     BlurRadius="4" 
                     ShadowDepth="0" 
                     Direction="90"/>

</ResourceDictionary>
