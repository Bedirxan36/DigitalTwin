<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 
    ═══════════════════════════════════════════════════════════════
    DIGITAL TWIN - MODERN DESIGN SYSTEM
    Premium Color Palette with Light & Dark Mode Support
    ═══════════════════════════════════════════════════════════════
    -->

    <!-- ═══ LIGHT MODE COLORS ═══ -->
    
    <!-- Primary Brand Colors - Indigo/Purple Gradient -->
    <Color x:Key="Primary50">#EEF2FF</Color>
    <Color x:Key="Primary100">#E0E7FF</Color>
    <Color x:Key="Primary200">#C7D2FE</Color>
    <Color x:Key="Primary300">#A5B4FC</Color>
    <Color x:Key="Primary400">#818CF8</Color>
    <Color x:Key="Primary500">#6366F1</Color>
    <Color x:Key="Primary600">#4F46E5</Color>
    <Color x:Key="Primary700">#4338CA</Color>
    <Color x:Key="Primary800">#3730A3</Color>
    <Color x:Key="Primary900">#312E81</Color>
    
    <!-- Secondary Colors - Violet -->
    <Color x:Key="Secondary400">#A78BFA</Color>
    <Color x:Key="Secondary500">#8B5CF6</Color>
    <Color x:Key="Secondary600">#7C3AED</Color>
    
    <!-- Accent Colors - Pink/Rose -->
    <Color x:Key="Accent400">#F472B6</Color>
    <Color x:Key="Accent500">#EC4899</Color>
    <Color x:Key="Accent600">#DB2777</Color>
    
    <!-- Semantic Colors -->
    <Color x:Key="Success400">#4ADE80</Color>
    <Color x:Key="Success500">#22C55E</Color>
    <Color x:Key="Success600">#16A34A</Color>
    
    <Color x:Key="Warning400">#FBBF24</Color>
    <Color x:Key="Warning500">#F59E0B</Color>
    <Color x:Key="Warning600">#D97706</Color>
    
    <Color x:Key="Error400">#F87171</Color>
    <Color x:Key="Error500">#EF4444</Color>
    <Color x:Key="Error600">#DC2626</Color>
    
    <Color x:Key="Info400">#60A5FA</Color>
    <Color x:Key="Info500">#3B82F6</Color>
    <Color x:Key="Info600">#2563EB</Color>
    
    <!-- Neutral/Gray Scale - Light Mode -->
    <Color x:Key="Gray50">#F9FAFB</Color>
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>
    <Color x:Key="Gray800">#1F2937</Color>
    <Color x:Key="Gray900">#111827</Color>
    
    <!-- Dark Mode Colors -->
    <Color x:Key="Dark50">#18181B</Color>
    <Color x:Key="Dark100">#27272A</Color>
    <Color x:Key="Dark200">#3F3F46</Color>
    <Color x:Key="Dark300">#52525B</Color>
    <Color x:Key="Dark400">#71717A</Color>
    <Color x:Key="Dark500">#A1A1AA</Color>
    <Color x:Key="Dark600">#D4D4D8</Color>
    <Color x:Key="Dark700">#E4E4E7</Color>
    <Color x:Key="Dark800">#F4F4F5</Color>
    <Color x:Key="Dark900">#FAFAFA</Color>
    
    <!-- ═══ LIGHT MODE THEME ═══ -->
    
    <!-- Background Colors -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource Gray50}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#FFFFFF"/>
    
    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource Gray800}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource Primary600}"/>
    
    <!-- Primary Brand -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary600}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource Primary700}"/>
    <SolidColorBrush x:Key="PrimaryActiveBrush" Color="{StaticResource Primary800}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource Primary400}"/>
    <SolidColorBrush x:Key="PrimarySubtleBrush" Color="{StaticResource Primary100}"/>
    
    <!-- Secondary -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary500}"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="{StaticResource Secondary600}"/>
    
    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent500}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource Accent600}"/>
    
    <!-- Semantic -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success500}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource Success400}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning500}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error500}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info500}"/>
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="{StaticResource Gray50}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>
    
    <!-- Border Colors -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="BorderMediumBrush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource Primary400}"/>
    
    <!-- Overlay & Shadow -->
    <SolidColorBrush x:Key="OverlayBrush" Color="#80000000"/>
    <SolidColorBrush x:Key="ScrimBrush" Color="#40000000"/>
    
    <!-- ═══ GRADIENTS ═══ -->
    
    <!-- Primary Gradient -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Primary600}" Offset="0"/>
        <GradientStop Color="{StaticResource Secondary600}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Accent Gradient -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Accent500}" Offset="0"/>
        <GradientStop Color="{StaticResource Primary500}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Success Gradient -->
    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Success400}" Offset="0"/>
        <GradientStop Color="{StaticResource Success600}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Sidebar Gradient -->
    <LinearGradientBrush x:Key="SidebarGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource Gray900}" Offset="0"/>
        <GradientStop Color="{StaticResource Gray800}" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
